#!/usr/bin/env python3
"""claudegrep — search Claude Code conversation logs.

Searches the JSONL session transcripts under ~/.claude/projects and renders
rich, session-grouped results. Uses a fast candidate-file pre-filter when
available and does a single parse pass per file in Python — no per-result
subprocess fan-out, so it stays well under a second for typical queries.

Stdlib only. The pre-filter falls back through ripgrep → grep → a pure-Python
scan, so it works with whatever is installed (just slower without `rg`).

Usage:
  claudegrep <pattern>              search conversation text (user + assistant)
  claudegrep -u <pattern>           user messages only
  claudegrep -a <pattern>           assistant messages only
  claudegrep -p <project> <pattern> filter to a project (dir-name substring)
  claudegrep -m <N> <pattern>       cap results (default 25; -n is an alias)
  claudegrep --all-content <pat>    also search tool calls + tool output
  claudegrep --list-projects        list projects
  claudegrep                        (no pattern) recent-sessions dashboard

Run `claudegrep --help` for the full flag list.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import unicodedata
from datetime import datetime, timedelta, timezone
from pathlib import Path

# ── Theme ────────────────────────────────────────────────────────────────────
# Truecolor palette (matches the original tool's design).


