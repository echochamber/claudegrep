    NAMES = {
        "RESET": "\033[0m",
        "BOLD": "\033[1m",
        "DIM": "\033[2m",
        "ITALIC": "\033[3m",
        "ORANGE": "\033[38;2;255;150;50m",
        "PEACH": "\033[38;2;255;180;120m",
        "CORAL": "\033[38;2;255;120;100m",
        "TEAL": "\033[38;2;100;220;200m",
        "SLATE": "\033[38;2;130;150;170m",
        "SKY": "\033[38;2;120;180;255m",
        "LAVENDER": "\033[38;2;180;160;255m",
        "MINT": "\033[38;2;120;230;170m",
        "CLOUD": "\033[38;2;80;90;105m",
        "WHITE": "\033[38;2;230;235;240m",
        "FAINT": "\033[38;2;90;100;110m",
        "GOLD": "\033[38;2;220;190;100m",
